{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://videomaker.local/schemas/visual-style-bible.schema.json",
  "title": "VisualStyleBible",
  "type": "object",
  "required": ["summary"],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 800
    },
    "palette": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "maxItems": 8
    },
    "lighting": { "type": "string", "maxLength": 200 },
    "cameraGrammar": { "type": "string", "maxLength": 200 },
    "mood": { "type": "string", "maxLength": 200 },
    "avoid": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "maxItems": 8
    },
    "derivedFrom": {
      "type": "object",
      "properties": {
        "structureId": { "type": "string" },
        "knowledgeEntryId": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
