{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://videomaker.local/schemas/knowledge-entry.schema.json",
  "title": "KnowledgeEntry",
  "type": "object",
  "required": [
    "id",
    "status",
    "title",
    "category",
    "style",
    "slotPattern",
    "summary",
    "skillMdUri",
    "structureJsonUri",
    "version",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["draft", "published", "archived"]
    },
    "title": { "type": "string", "minLength": 1 },
    "category": { "type": "string", "minLength": 1 },
    "categorySlug": { "type": "string", "minLength": 1 },
    "style": { "type": "string", "minLength": 1 },
    "hookType": { "type": "string" },
    "tempo": {
      "type": "string",
      "enum": ["slow", "medium", "fast", "mixed"]
    },
    "durationBucket": { "type": "string" },
    "slotPattern": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "skillMdUri": { "type": "string", "minLength": 1 },
    "structureJsonUri": { "type": "string", "minLength": 1 },
    "sourceProjectId": { "type": "string" },
    "sourceSampleId": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
