{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://videomaker.local/schemas/project-knowledge-selection.schema.json",
  "title": "ProjectKnowledgeSelection",
  "type": "object",
  "required": [
    "projectId",
    "referenceEntryIds",
    "mode",
    "appliedAsStructure",
    "updatedAt"
  ],
  "properties": {
    "projectId": { "type": "string", "minLength": 1 },
    "primaryEntryId": { "type": ["string", "null"] },
    "referenceEntryIds": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "mode": {
      "type": "string",
      "enum": ["auto", "user_override", "none"]
    },
    "appliedAsStructure": { "type": "boolean" },
    "recommendationSnapshot": { "$ref": "knowledge-recommendation.schema.json" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
