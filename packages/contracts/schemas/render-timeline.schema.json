{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://videomaker.local/schemas/render-timeline.schema.json",
  "title": "RenderTimeline",
  "type": "object",
  "required": ["durationSec", "tracks"],
  "properties": {
    "durationSec": { "type": "number", "minimum": 0 },
    "tracks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "clips"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": {
            "type": "string",
            "enum": ["video", "image", "text", "voiceover", "bgm", "effect", "transition"]
          },
          "clips": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "startSec", "endSec"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "startSec": { "type": "number", "minimum": 0 },
                "endSec": { "type": "number", "minimum": 0 },
                "sourceRef": { "type": "string" },
                "content": { "type": "string" },
                "styleRef": { "type": "string" },
                "transform": {
                  "type": "object",
                  "properties": {
                    "x": { "type": "number" },
                    "y": { "type": "number" },
                    "scale": { "type": "number" },
                    "rotation": { "type": "number" },
                    "opacity": { "type": "number", "minimum": 0, "maximum": 1 }
                  },
                  "additionalProperties": false
                },
                "generatedBy": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
