{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://videomaker.local/schemas/knowledge-skill-output.schema.json",
  "title": "KnowledgeSkillOutput",
  "type": "object",
  "required": ["frontmatter", "markdown"],
  "properties": {
    "frontmatter": {
      "type": "object",
      "required": ["title", "category", "style", "summary"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "category": { "type": "string", "minLength": 1 },
        "style": { "type": "string", "minLength": 1 },
        "hookType": { "type": "string" },
        "tempo": {
          "type": "string",
          "enum": ["slow", "medium", "fast", "mixed"]
        },
        "durationBucket": { "type": "string" },
        "slotPattern": { "type": "string" },
        "summary": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "markdown": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
