{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://videomaker.local/schemas/knowledge-category-summary.schema.json",
  "title": "KnowledgeCategorySummary",
  "type": "object",
  "required": [
    "category",
    "categorySlug",
    "entryCount",
    "summary",
    "slotPatterns",
    "updatedAt"
  ],
  "properties": {
    "category": { "type": "string", "minLength": 1 },
    "categorySlug": { "type": "string", "minLength": 1 },
    "entryCount": { "type": "integer", "minimum": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "coverUrl": { "type": ["string", "null"] },
    "slotPatterns": {
      "type": "array",
      "items": { "type": "string" }
    },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
