{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://videomaker.local/schemas/revise-planner-output.schema.json",
  "title": "RevisePlannerOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary",
    "costTier",
    "requiresFullRender",
    "executionMode",
    "intents",
    "executionSteps"
  ],
  "properties": {
    "summary": { "type": "string", "minLength": 1 },
    "costTier": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "requiresFullRender": { "type": "boolean" },
    "executionMode": {
      "type": "string",
      "enum": ["in_place", "fork"]
    },
    "intents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["target", "operation", "params", "rationale"],
        "properties": {
          "target": {
            "type": "string",
            "enum": [
              "generation_plan.storyboard",
              "generation_plan.packaging",
              "render_timeline",
              "generation_params"
            ]
          },
          "operation": {
            "type": "string",
            "enum": [
              "adjust_hook",
              "reduce_subtitles",
              "increase_subtitles",
              "reorder_selling_points",
              "change_pace",
              "change_packaging_style",
              "adjust_cta",
              "subtitle_patch",
              "timeline_scene_patch",
              "packaging_scene_patch"
            ]
          },
          "params": { "type": "object" },
          "rationale": { "type": "string" },
          "scope": {
            "type": "string",
            "enum": [
              "global",
              "scene",
              "track_subtitle",
              "track_audio",
              "track_video",
              "packaging"
            ]
          },
          "sceneIds": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "slotIds": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "executionTool": {
            "type": "string",
            "enum": [
              "subtitle_patch",
              "timeline_scene_patch",
              "packaging_scene_patch",
              "script_revise",
              "packaging_agent",
              "storyboard_agent",
              "material_regen",
              "full_pipeline"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "executionSteps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["tool"],
        "properties": {
          "tool": { "type": "string", "minLength": 1 },
          "params": { "type": "object" },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "affectedSceneIds": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "affectedSlotIds": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "conversationSummary": { "type": "string" }
  }
}
