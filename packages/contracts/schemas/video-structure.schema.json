{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://videomaker.local/schemas/video-structure.schema.json",
  "title": "VideoStructure",
  "type": "object",
  "required": [
    "id",
    "projectId",
    "sourceVideoId",
    "version",
    "metadata",
    "narrative",
    "rhythm",
    "slots",
    "evidence",
    "confidence",
    "context",
    "verbal",
    "visual",
    "audio",
    "transfer",
    "analysisQuality"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "projectId": { "type": "string", "minLength": 1 },
    "sourceVideoId": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "enum": ["p1-v3"] },
    "metadata": {
      "type": "object",
      "required": ["durationSec"],
      "properties": {
        "durationSec": { "type": "number", "minimum": 0 },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "fps": { "type": "number", "minimum": 0 },
        "codec": { "type": "string" },
        "hasAudio": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "context": {
      "type": "object",
      "required": ["contentCategory", "platformFormat", "primaryIntent", "successHypothesis", "applicability"],
      "properties": {
        "contentCategory": {
          "type": "string",
          "enum": [
            "product_commerce",
            "education",
            "vlog_lifestyle",
            "brand_story",
            "tutorial",
            "entertainment",
            "news_commentary",
            "general"
          ]
        },
        "platformFormat": { "type": "string" },
        "primaryIntent": {
          "type": "string",
          "enum": ["exposure", "consideration", "conversion"]
        },
        "successHypothesis": { "type": "string" },
        "applicability": {
          "type": "object",
          "required": ["suitableFor", "unsuitableFor"],
          "properties": {
            "suitableFor": { "type": "array", "items": { "type": "string" } },
            "unsuitableFor": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "verbal": {
      "type": "object",
      "required": ["hookTemplate", "outlineTimeline", "ctaMechanism"],
      "properties": {
        "hookTemplate": { "type": "string" },
        "outlineTimeline": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["phase", "startSec", "endSec", "sharePct"],
            "properties": {
              "phase": { "type": "string" },
              "startSec": { "type": "number", "minimum": 0 },
              "endSec": { "type": "number", "minimum": 0 },
              "sharePct": { "type": "number", "minimum": 0, "maximum": 1 }
            },
            "additionalProperties": false
          }
        },
        "ctaMechanism": { "type": "string" },
        "infoLubricantRatio": {
          "type": "object",
          "properties": {
            "infoSec": { "type": "number", "minimum": 0 },
            "lubricantSec": { "type": "number", "minimum": 0 },
            "ratio": { "type": "number", "minimum": 0 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "visual": {
      "type": "object",
      "properties": {
        "conceptVisualMap": {
          "type": "array",
          "maxItems": 8,
          "items": {
            "type": "object",
            "required": ["concept", "visualMetaphor"],
            "properties": {
              "concept": { "type": "string" },
              "visualMetaphor": { "type": "string" },
              "timeSec": { "type": "number", "minimum": 0 },
              "assetHint": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "cutRateProfile": {
          "type": "object",
          "properties": {
            "avgShotSec": { "type": "number", "minimum": 0 },
            "openingCutRate": { "type": "string" },
            "fastCutRanges": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["startSec", "endSec"],
                "properties": {
                  "startSec": { "type": "number", "minimum": 0 },
                  "endSec": { "type": "number", "minimum": 0 }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "packagingSpec": {
          "type": "object",
          "properties": {
            "visualDensity": { "type": "string", "enum": ["low", "medium", "high"] },
            "summary": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "audio": {
      "type": "object",
      "properties": {
        "voProfile": {
          "type": "object",
          "properties": {
            "pace": { "type": "string" },
            "energy": { "type": "string" },
            "persona": { "type": "string" },
            "wordsPerMinute": { "type": "number", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "audioEventRules": {
          "type": "array",
          "maxItems": 5,
          "items": {
            "type": "object",
            "required": ["trigger", "action"],
            "properties": {
              "trigger": { "type": "string" },
              "action": { "type": "string" },
              "timeSec": { "type": "number", "minimum": 0 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "transfer": {
      "type": "object",
      "required": [
        "structureFamily",
        "differentiationLever",
        "emotionTriggers",
        "scalabilityRules",
        "nonTransferableElements"
      ],
      "properties": {
        "structureFamily": { "type": "string" },
        "differentiationLever": { "type": "string" },
        "emotionTriggers": {
          "type": "array",
          "maxItems": 5,
          "items": {
            "type": "object",
            "required": ["timeSec", "triggerType", "segmentId", "mechanism"],
            "properties": {
              "timeSec": { "type": "number", "minimum": 0 },
              "triggerType": { "type": "string" },
              "segmentId": { "type": "string" },
              "mechanism": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "scalabilityRules": { "type": "string" },
        "nonTransferableElements": { "type": "array", "items": { "type": "string" } },
        "materialRequirementsSummary": { "type": "string" }
      },
      "additionalProperties": false
    },
    "narrative": {
      "type": "object",
      "required": ["summary", "segments"],
      "properties": {
        "summary": { "type": "string" },
        "segments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "role", "startSec", "endSec", "scriptSummary", "visualSummary", "intent"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "role": {
                "type": "string",
                "enum": ["hook", "problem", "solution", "proof", "benefit", "comparison", "cta", "transition"]
              },
              "startSec": { "type": "number", "minimum": 0 },
              "endSec": { "type": "number", "minimum": 0 },
              "scriptSummary": { "type": "string" },
              "visualSummary": { "type": "string" },
              "intent": { "type": "string" },
              "transcriptExcerpt": { "type": "string", "maxLength": 120 },
              "rhetoricalDevices": { "type": "array", "items": { "type": "string" } },
              "emotionTone": { "type": "string" },
              "voStyle": {
                "type": "object",
                "properties": {
                  "pace": { "type": "string" },
                  "energy": { "type": "string" },
                  "persona": { "type": "string" }
                },
                "additionalProperties": false
              },
              "visualSpec": {
                "type": "object",
                "properties": {
                  "framing": { "type": "string" },
                  "subject": { "type": "string" },
                  "cameraMove": { "type": "string" },
                  "onScreenText": { "type": "array", "items": { "type": "string" } },
                  "colorMood": { "type": "string" },
                  "density": { "type": "string", "enum": ["low", "medium", "high"] }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "rhythm": {
      "type": "object",
      "required": ["totalDurationSec", "shotCount", "avgShotDurationSec", "tempo", "beatPoints", "shotBoundaries"],
      "properties": {
        "totalDurationSec": { "type": "number", "minimum": 0 },
        "shotCount": { "type": "integer", "minimum": 0 },
        "avgShotDurationSec": { "type": "number", "minimum": 0 },
        "tempo": { "type": "string", "enum": ["slow", "medium", "fast", "mixed"] },
        "climaxSec": { "type": "number", "minimum": 0 },
        "beatPoints": {
          "type": "array",
          "maxItems": 12,
          "items": { "type": "number", "minimum": 0 }
        },
        "shotBoundaries": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["startSec", "endSec", "confidence", "changeReason"],
            "properties": {
              "startSec": { "type": "number", "minimum": 0 },
              "endSec": { "type": "number", "minimum": 0 },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
              "changeReason": {
                "type": "string",
                "enum": ["visual_cut", "scene_change", "caption_change", "beat", "unknown"]
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "slots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "segmentId", "role", "startSec", "endSec", "requiredAssetType", "visualIntent", "scriptIntent", "importance", "constraints"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "segmentId": { "type": "string", "minLength": 1 },
          "role": {
            "type": "string",
            "enum": ["hook_visual", "hook_text", "product_closeup", "usage_scene", "benefit_card", "comparison", "proof", "transition", "cta"]
          },
          "startSec": { "type": "number", "minimum": 0 },
          "endSec": { "type": "number", "minimum": 0 },
          "requiredAssetType": {
            "type": "array",
            "items": { "type": "string", "enum": ["video", "image", "text", "voiceover", "generated_visual", "packaging"] },
            "minItems": 1
          },
          "visualIntent": { "type": "string" },
          "scriptIntent": { "type": "string" },
          "packagingHint": { "type": "string" },
          "importance": { "type": "string", "enum": ["must_have", "recommended", "optional"] },
          "constraints": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
          "durationSharePct": { "type": "number", "minimum": 0, "maximum": 1 },
          "migrationTemplate": { "type": "string" },
          "packagingRequirements": { "type": "array", "items": { "type": "string" } },
          "antiPatterns": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["targetId", "source", "summary", "confidence"],
        "properties": {
          "targetId": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "enum": ["asr", "ocr", "keyframe", "shot_detection", "audio", "llm"] },
          "summary": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "timeRange": {
            "type": "object",
            "required": ["startSec", "endSec"],
            "properties": {
              "startSec": { "type": "number", "minimum": 0 },
              "endSec": { "type": "number", "minimum": 0 }
            },
            "additionalProperties": false
          },
          "excerpt": { "type": "string" },
          "artifactRef": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "analysisQuality": {
      "type": "object",
      "required": ["warnings", "locale", "promoteReady"],
      "properties": {
        "warnings": { "type": "array", "items": { "type": "string" } },
        "locale": { "type": "string" },
        "promoteReady": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "additionalProperties": false
}
